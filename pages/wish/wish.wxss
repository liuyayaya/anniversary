/* pages/wish/wish.wxss */
.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 30rpx;
  padding-bottom: 120rpx;
}

.filter {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.filter-item {
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item.active {
  background: #ff6b9d;
  color: #fff;
}

.wish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.wish-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.wish-item.done {
  opacity: 0.6;
}

.wish-item.done .wish-title {
  text-decoration: line-through;
}

.wish-check {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.wish-info {
  flex: 1;
}

.wish-title {
  font-size: 28rpx;
  color: #333;
}

.wish-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.wish-actions {
  display: flex;
  gap: 16rpx;
}

.wish-actions text {
  font-size: 24rpx;
  color: #ff6b9d;
  padding: 10rpx;
}

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx;
  font-size: 26rpx;
}

.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #ff6b9d, #ff9a8b);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 157, 0.4);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.modal-input {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-btn {
  background: linear-gradient(135deg, #ff6b9d, #ff9a8b);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 30rpx;
}