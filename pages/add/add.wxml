<!--pages/add/add.wxml-->
<view class="container">
  <view class="form">
    <!-- 标题 -->
    <view class="form-item">
      <text class="label">标题</text>
      <input 
        class="input" 
        placeholder="如：结婚纪念日、老婆生日" 
        value="{{title}}"
        bindinput="onTitleInput"
      />
    </view>

    <!-- 日期 -->
    <view class="form-item">
      <text class="label">日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="picker">
          <text wx:if="{{date}}">{{date}}</text>
          <text wx:else class="placeholder">选择日期</text>
        </view>
      </picker>
    </view>

    <!-- 类型 -->
    <view class="form-item">
      <text class="label">类型</text>
      <view class="type-grid">
        <block wx:for="{{types}}" wx:key="value">
          <view 
            class="type-item {{type === item.value ? 'active' : ''}}"
            bindtap="onTypeChange"
            data-index="{{index}}"
          >
            <text>{{item.icon}}</text>
            <text>{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 循环周期 -->
    <view class="form-item">
      <text class="label">循环周期</text>
      <picker mode="selector" range="{{cycles}}" range-key="label" bindchange="onCycleChange">
        <view class="picker">
          {{cycles[cycles.findIndex(c => c.value === cycle)].label}}
        </view>
      </picker>
    </view>

    <!-- 提醒设置 -->
    <view class="form-item">
      <view class="switch-row">
        <text class="label">提醒通知</text>
        <switch checked="{{reminder}}" bindchange="onReminderChange" color="#ff6b9d"/>
      </view>
    </view>

    <view class="form-item" wx:if="{{reminder}}">
      <text class="label">提前提醒</text>
      <picker mode="selector" range="{{reminderOptions}}" bindchange="onReminderDaysChange">
        <view class="picker">
          提前 {{reminderOptions[reminderOptions.findIndex(r => r === reminderDays)]}} 天
        </view>
      </picker>
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="save">保存</button>
</view>