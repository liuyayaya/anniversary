/* pages/add/add.wxss */
.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 30rpx;
}

.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.form-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 20rpx;
}

.input {
  font-size: 30rpx;
  color: #333;
}

.picker {
  font-size: 30rpx;
  color: #333;
  padding: 20rpx 0;
}

.placeholder {
  color: #999;
}

.type-grid {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.type-item.active {
  border-color: #ff6b9d;
  background: #ffe6ee;
  color: #ff6b9d;
}

.type-item text:first-child {
  font-size: 40rpx;
  display: block;
  margin-bottom: 10rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.save-btn {
  margin-top: 60rpx;
  background: linear-gradient(135deg, #ff6b9d, #ff9a8b);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 32rpx;
}