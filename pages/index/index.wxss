/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffe6ee 0%, #fff 30%);
  padding-bottom: 120rpx;
}

.header {
  padding: 40rpx 30rpx 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b9d;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.section {
  padding: 20rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 即将到来 */
.upcoming-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.upcoming-list {
  display: flex;
  gap: 20rpx;
}

.upcoming-card {
  display: inline-block;
  width: 200rpx;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #ff6b9d, #ff9a8b);
  border-radius: 20rpx;
  text-align: center;
  flex-shrink: 0;
}

.upcoming-days {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.upcoming-title {
  font-size: 26rpx;
  color: #fff;
  margin-top: 10rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upcoming-date {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

/* 列表 */
.list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.anniversary-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  background: #ffe6ee;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.item-info {
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.item-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.delete-btn {
  font-size: 36rpx;
  padding: 10rpx;
}

.empty {
  padding: 80rpx 30rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #ff6b9d, #ff9a8b);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 157, 0.4);
}